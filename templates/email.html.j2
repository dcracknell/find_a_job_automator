{# email.html.j2 — rendered by output/email_digest.py (built in Phase 3) #}
{# Mobile-first HTML email: single column, max-width 600px, large tap targets #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <style>
    body { margin: 0; padding: 0; background: #f3f4f6; font-family: system-ui, sans-serif; }
    .wrapper { max-width: 600px; margin: 0 auto; background: white; }
    .header { background: #1d4ed8; color: white; padding: 24px; }
    .header h1 { margin: 0; font-size: 1.25rem; }
    .header p { margin: 4px 0 0; font-size: 0.875rem; opacity: 0.9; }
    .section { padding: 20px 24px; border-bottom: 1px solid #e5e7eb; }
    .section h2 { font-size: 1rem; color: #374151; margin: 0 0 12px; }
    .job-card { border: 1px solid #e5e7eb; border-radius: 6px; padding: 12px; margin-bottom: 10px; }
    .job-card .score { display: inline-block; padding: 2px 8px; border-radius: 12px; font-weight: bold; font-size: 0.875rem; margin-bottom: 6px; }
    .score-high { background: #dcfce7; color: #166534; }
    .score-mid  { background: #fef9c3; color: #713f12; }
    .score-low  { background: #fee2e2; color: #991b1b; }
    .job-card .title { font-size: 1rem; font-weight: 600; margin: 0 0 4px; }
    .job-card .meta  { font-size: 0.8rem; color: #6b7280; }
    .job-card a { display: block; margin-top: 8px; padding: 10px; background: #2563eb; color: white; text-decoration: none; border-radius: 4px; text-align: center; }
    .closes-soon { background: #fef2f2; border-left: 4px solid #dc2626; }
    .summary-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .summary-table td { padding: 6px 8px; border-bottom: 1px solid #f3f4f6; }
    .footer { padding: 16px 24px; font-size: 0.75rem; color: #9ca3af; }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="header">
    <h1>{{ subject }}</h1>
    <p>{{ run_date }} · {{ jobs_new }} new · {{ jobs_high_fit }} high-fit</p>
  </div>

  {% if closing_soon %}
  <div class="section">
    <h2>⚠ Closing Soon (within 7 days)</h2>
    {% for job in closing_soon %}
    <div class="job-card closes-soon">
      <div class="title">{{ job.title }} — {{ job.company }}</div>
      <div class="meta">{{ job.location }} · Closes {{ job.closes_on }} · Score {{ job.fit_score | round(1) if job.fit_score else '—' }}</div>
      <a href="{{ job.url }}">View Job →</a>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if high_fit %}
  <div class="section">
    <h2>★ New High-Fit Jobs (score ≥ 7)</h2>
    {% for job in high_fit %}
    <div class="job-card">
      <span class="score score-high">{{ job.fit_score | round(1) }}</span>
      <div class="title">{{ job.title }}</div>
      <div class="meta">{{ job.company }} · {{ job.location }}</div>
      <div class="meta">{{ job.fit_reason }}</div>
      <a href="{{ job.url }}">View Job →</a>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if mid_fit %}
  <div class="section">
    <h2>New Medium-Fit Jobs (score 5–6.9)</h2>
    {% for job in mid_fit %}
    <div class="job-card">
      <span class="score score-mid">{{ job.fit_score | round(1) }}</span>
      <div class="title">{{ job.title }} — {{ job.company }}</div>
      <div class="meta">{{ job.location }} · {{ job.fit_reason }}</div>
      <a href="{{ job.url }}">View Job →</a>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="section">
    <h2>Pipeline Summary</h2>
    <table class="summary-table">
      {% for status, count in status_counts.items() %}
      <tr><td>{{ status }}</td><td><strong>{{ count }}</strong></td></tr>
      {% endfor %}
    </table>
  </div>

  {% if adapter_health %}
  <div class="section">
    <h2>Adapter Health</h2>
    <table class="summary-table">
      {% for name, ok, error in adapter_health %}
      <tr>
        <td>{{ name }}</td>
        <td>{{ '✓' if ok else '✗ ' + error }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}

  <div class="footer">
    <p>Today's API spend: £{{ quota_today }}</p>
    {% if dashboard_url %}
    <p><a href="{{ dashboard_url }}">View full dashboard →</a></p>
    {% endif %}
    <p>Unsubscribe: set <code>mode: paused</code> in config/settings.yaml</p>
  </div>
</div>
</body>
</html>
